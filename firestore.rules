rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // 1. GLOBAL SAFETY NET
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // 2. REUSABLE PRIMITIVES AND HELPERS
    // ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // ---------------------------------------------------------
    // 3. VALIDATION BLUEPRINTS
    // ---------------------------------------------------------
    
    function isValidOrgChartData(data) {
      return data.keys().hasAll(['ownerId', 'settings', 'createdAt', 'updatedAt'])
        && data.keys().size() == 4
        && data.ownerId == request.auth.uid
        && data.settings is map
        && data.settings.size() <= 30
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidNodeData(data) {
      // name, title, department, email, phone, relationship, influence, isPlaceholder, notes, customFields, managerId, createdAt, updatedAt, ownerId
      return data.keys().hasAll([
          'ownerId', 'name', 'title', 'department', 'email', 'phone', 
          'relationship', 'influence', 'isPlaceholder', 
          'createdAt', 'updatedAt'
        ])
        // We allow up to 14 fields (including optional notes, managerId, customFields)
        && data.keys().size() <= 14
        && data.ownerId == request.auth.uid
        && data.name is string && data.name.size() <= 200
        && data.title is string && data.title.size() <= 200
        && data.department is string && data.department.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.phone is string && data.phone.size() <= 100
        && data.relationship is string && data.relationship.size() <= 20
        && data.influence is string && data.influence.size() <= 20
        && data.isPlaceholder is bool
        && (!data.keys().hasAny(['notes']) || (data.notes is string && data.notes.size() <= 2000))
        && (!data.keys().hasAny(['managerId']) || (data.managerId == null || (data.managerId is string && data.managerId.size() <= 128)))
        && (!data.keys().hasAny(['customFields']) || (data.customFields is map && data.customFields.size() <= 20))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // ---------------------------------------------------------
    // 4. ENTITY RULES
    // ---------------------------------------------------------

    match /orgCharts/{chartId} {
      allow get: if isSignedIn() && isValidId(chartId) && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(chartId) 
        && isValidOrgChartData(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn() 
        && isValidId(chartId) 
        && existing().ownerId == request.auth.uid
        && isValidOrgChartData(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['settings', 'updatedAt']);
        
      allow delete: if isSignedIn() 
        && isValidId(chartId) 
        && existing().ownerId == request.auth.uid;

      match /nodes/{nodeId} {
        // Relational Master Gate: Must own parent to access subcollection
        function isParentOwner() {
          return get(/databases/$(database)/documents/orgCharts/$(chartId)).data.ownerId == request.auth.uid;
        }

        allow get: if isSignedIn() && isValidId(chartId) && isValidId(nodeId) && isParentOwner();
        allow list: if isSignedIn() && isValidId(chartId) && resource.data.ownerId == request.auth.uid;
        
        allow create: if isSignedIn() 
          && isValidId(chartId) 
          && isValidId(nodeId) 
          && isParentOwner()
          && isValidNodeData(incoming())
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;
          
        allow update: if isSignedIn() 
          && isValidId(chartId) 
          && isValidId(nodeId) 
          && isParentOwner()
          && existing().ownerId == request.auth.uid
          && isValidNodeData(incoming())
          && incoming().ownerId == existing().ownerId
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time
          // All fields can be updated except createdAt and ownerId
          && incoming().diff(existing()).affectedKeys().hasOnly([
            'name', 'title', 'department', 'email', 'phone', 
            'relationship', 'influence', 'isPlaceholder', 
            'notes', 'managerId', 'customFields', 'updatedAt'
          ]);
          
        allow delete: if isSignedIn() 
          && isValidId(chartId) 
          && isValidId(nodeId) 
          && isParentOwner();
      }
    }
  }
}
